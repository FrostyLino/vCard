{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vCard Editor",
  "version": "1.2.0",
  "identifier": "com.frostylino.vcard",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "vCard Editor",
        "width": 1420,
        "height": 920,
        "minWidth": 1120,
        "minHeight": 760,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg",
      "appimage",
      "nsis"
    ],
    "copyright": "Copyright (c) 2026 Lino Seydel",
    "license": "MIT",
    "licenseFile": "../LICENSE",
    "category": "Productivity",
    "shortDescription": "Safe single-contact and batch editing for .vcf files on macOS, Ubuntu and Windows",
    "longDescription": "vCard Editor is a desktop app for macOS, Ubuntu and Windows that opens, validates, edits and safely saves .vcf files in both single-contact and batch workflows. It supports draft creation, batch patching, inline power-table editing, photos, business-card metadata, instant-messaging URIs, live raw preview and conservative roundtrips for unknown properties.",
    "fileAssociations": [
      {
        "ext": [
          "vcf"
        ],
        "name": "vCard contact file",
        "description": "vCard contact file",
        "role": "Editor",
        "mimeType": "text/vcard"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
