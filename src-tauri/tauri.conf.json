{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vCard Editor",
  "version": "1.0.0",
  "identifier": "com.frostylino.vcard",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "vCard Editor",
        "width": 1420,
        "height": 920,
        "minWidth": 1120,
        "minHeight": 760,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "copyright": "Copyright (c) 2026 Lino Seydel",
    "license": "MIT",
    "licenseFile": "../LICENSE",
    "category": "Productivity",
    "shortDescription": "Focused editor for single .vcf contact files",
    "longDescription": "vCard Editor is a macOS-first desktop app for opening, validating, editing and safely saving a single vCard file at a time. It supports photos, business-card metadata, instant-messaging URIs, live raw preview and conservative roundtrips for unknown properties.",
    "fileAssociations": [
      {
        "ext": [
          "vcf"
        ],
        "name": "vCard contact file",
        "description": "vCard contact file",
        "role": "Editor",
        "mimeType": "text/vcard"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
